# ============================
# Telegram
# ============================
BOT_TOKEN=PUT_YOUR_BOT_TOKEN_FROM_BOTFATHER
BOT_BRAND=Сказка
ADMIN_IDS=123456789

# ============================
# ЮKassa
# ============================
# provider_token получаем у @BotFather: /mybots → выбрать бота → Payments → ЮKassa
YOOKASSA_PROVIDER_TOKEN=PUT_YOUR_PROVIDER_TOKEN

# Для рекуррентов нужны прямые API-ключи ЮKassa (личный кабинет → Интеграция → API-ключи)
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# ============================
# LLM-провайдер
# anthropic — Claude Sonnet 4.6 (премиум, дороже, заметно лучше языком)
# gemini    — Gemini 2.5 Flash (бэкап / эконом-режим)
# ============================
LLM_PROVIDER=anthropic

# Anthropic — https://console.anthropic.com (это НЕ та же подписка что Claude.ai Pro!)
# Pay-as-you-go: $3/M input, $15/M output. С prompt-caching одна сказка ~2.8 ₽.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Gemini (AI Studio: https://aistudio.google.com/apikey) — fallback или эконом
GEMINI_API_KEY=PUT_YOUR_GEMINI_KEY
GEMINI_MODEL_FREE=gemini-2.5-flash-lite
GEMINI_MODEL_PAID=gemini-2.5-flash

# ============================
# TTS-провайдер
# azure       — Azure Neural TTS (новый primary, $16/M chars ≈ 7 ₽/сказка)
# yandex      — Яндекс SpeechKit (старый, дешёвый, средний по качеству)
# elevenlabs  — последний fallback
# ============================
TTS_PROVIDER=azure

# Azure Cognitive Services Speech — см. SETUP_PREMIUM_STACK.md
# Region: westeurope/northeurope для минимальной задержки.
# Voice: ru-RU-SvetlanaNeural (тёплая мама), ru-RU-DariyaNeural (мягкая молодая).
# Style: affectionate / chat / gentle / friendly (см. Azure docs).
# Rate: -8% = чуть медленнее норма (для сказок на ночь хорошо).
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=westeurope
AZURE_TTS_VOICE=ru-RU-SvetlanaNeural
AZURE_TTS_STYLE=affectionate
AZURE_TTS_RATE=-8%

# Яндекс SpeechKit (fallback)
YANDEX_API_KEY=
YANDEX_FOLDER_ID=
YANDEX_TTS_VOICE=alena
YANDEX_TTS_EMOTION=good
YANDEX_TTS_SPEED=0.95

# ElevenLabs (последний fallback) — https://elevenlabs.io → Profile → API Keys
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=gD1IexrzCvsXPHUuT0s3
ELEVENLABS_MODEL=eleven_turbo_v2_5

# ============================
# Suno V5 (фоновая инструментальная музыка, генерится разово админом /generate_ambient)
# ============================
KIE_API_KEY=
SUNO_MODEL=V5

# ============================
# Картинка-обложка
# Модель выбирается через IMAGE_MODEL:
#   recraft-v3   — заточен под книжную/детскую иллюстрацию, ~3.6 ₽ (рекомендуется)
#   flux-pro-1.1 — фотогенично-иллюстративный, ~3.6 ₽
#   flux-dev     — заметно лучше Schnell, ~2.3 ₽
#   flux-schnell — дёшево и сердито, 0.3 ₽
# Платится через FAL.AI — один ключ FAL_KEY для всех моделей.
# FusionBrain (Kandinsky) — legacy fallback, если задан — используется когда FAL недоступен.
# ============================
IMAGE_MODEL=recraft-v3
FAL_KEY=

# FusionBrain (legacy fallback). Если хочешь полностью отключить — оставь пустыми.
FUSIONBRAIN_API_KEY=
FUSIONBRAIN_SECRET_KEY=

# ============================
# БД
# ============================
DB_URL=postgresql+asyncpg://skazka:skazka@db:5432/skazka

# ============================
# Лимиты / тарифы (копейки)
# ============================
# Бесплатная первая сказка (потом paywall)
FREE_STORY_LIMIT=1
REFERRAL_BONUS=3

# Разово — одна сказка, без лимитов на сутки
PRICE_SINGLE_KOPECKS=9900

# Пакет 15 сказок (одна в день, −34% от штучной цены)
PRICE_PACK_KOPECKS=99900
PACK_STORIES_COUNT=15

# Подписка на календарный месяц (одна в день, −50% от штучной цены, рекуррент)
PRICE_MONTHLY_KOPECKS=148500

# Подарочная сказка (если оставляешь функцию /gift) — отдельный товар
PRICE_GIFT_KOPECKS=19900

# ============================
# Прочее
# ============================
ENV=production
LOG_LEVEL=INFO
SENTRY_DSN=
AUDIO_CACHE_DIR=./cache/audio
IMAGE_CACHE_DIR=./cache/images
