# ============================
# Telegram
# ============================
BOT_TOKEN=PUT_YOUR_BOT_TOKEN_FROM_BOTFATHER
BOT_BRAND=Сказка
ADMIN_IDS=123456789

# ============================
# ЮKassa
# ============================
# provider_token получаем у @BotFather: /mybots → выбрать бота → Payments → ЮKassa
YOOKASSA_PROVIDER_TOKEN=PUT_YOUR_PROVIDER_TOKEN

# Для рекуррентов нужны прямые API-ключи ЮKassa (личный кабинет → Интеграция → API-ключи)
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# ============================
# Gemini (AI Studio: https://aistudio.google.com/apikey)
# ============================
GEMINI_API_KEY=PUT_YOUR_GEMINI_KEY
GEMINI_MODEL_FREE=gemini-2.5-flash-lite
GEMINI_MODEL_PAID=gemini-2.5-flash

# ============================
# ElevenLabs (только для платных юзеров)
# https://elevenlabs.io → Profile → API Keys
# ============================
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=GN4wbsbejSnGSa1AzjH5
ELEVENLABS_MODEL=eleven_turbo_v2_5

# ============================
# Картинка-обложка — два провайдера. Заполни ТОЛЬКО ОДИН.
# Приоритет: если заполнены оба, используется FusionBrain.
# ============================

# Вариант A — FusionBrain (Kandinsky 3.x от Сбера). Платится рублями.
# https://fusionbrain.ai → войти → API → Создать ключ
FUSIONBRAIN_API_KEY=
FUSIONBRAIN_SECRET_KEY=

# Вариант Б — FAL.AI (Flux Schnell). Платится зарубежной картой.
# https://fal.ai/dashboard/keys
FAL_KEY=
FAL_MODEL=fal-ai/flux/schnell

# ============================
# БД
# ============================
DB_URL=postgresql+asyncpg://skazka:skazka@db:5432/skazka

# ============================
# Лимиты / тарифы
# ============================
FREE_STORY_LIMIT=3
REFERRAL_BONUS=3
PRICE_SUB_KOPECKS=49000
PRICE_GIFT_KOPECKS=19900

# ============================
# Прочее
# ============================
ENV=production
LOG_LEVEL=INFO
SENTRY_DSN=
AUDIO_CACHE_DIR=./cache/audio
IMAGE_CACHE_DIR=./cache/images
