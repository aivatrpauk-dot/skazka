# ============================
# Telegram
# ============================
BOT_TOKEN=PUT_YOUR_BOT_TOKEN_FROM_BOTFATHER
BOT_BRAND=Сказка
ADMIN_IDS=123456789

# ============================
# ЮKassa
# ============================
# provider_token получаем у @BotFather: /mybots → выбрать бота → Payments → ЮKassa
YOOKASSA_PROVIDER_TOKEN=PUT_YOUR_PROVIDER_TOKEN

# Для рекуррентов нужны прямые API-ключи ЮKassa (личный кабинет → Интеграция → API-ключи)
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# ============================
# LLM-провайдер
# anthropic — Claude Sonnet 4.6 (премиум, дороже, заметно лучше языком)
# gemini    — Gemini 2.5 Flash (бэкап / эконом-режим)
# ============================
LLM_PROVIDER=anthropic

# Anthropic — https://console.anthropic.com (это НЕ та же подписка что Claude.ai Pro!)
# Pay-as-you-go: $3/M input, $15/M output. С prompt-caching одна сказка ~2.8 ₽.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Gemini (AI Studio: https://aistudio.google.com/apikey) — fallback или эконом
GEMINI_API_KEY=PUT_YOUR_GEMINI_KEY
GEMINI_MODEL_FREE=gemini-2.5-flash-lite
GEMINI_MODEL_PAID=gemini-2.5-flash

# ============================
# Озвучка (TTS) и фоновая музыка удалены в мае 2026 — продукт стал чистым PDF.
# Раньше тут жили USE_TTS, TTS_PROVIDER, AZURE_*, YANDEX_*, ELEVENLABS_*,
# KIE_API_KEY, SUNO_MODEL. Если когда-то понадобится вернуть голос —
# смотрите git-историю на коммит «убрать аудио код».
# ============================
# Картинка-обложка
# Модель выбирается через IMAGE_MODEL:
#   recraft-v3   — заточен под книжную/детскую иллюстрацию, ~3.6 ₽ (рекомендуется)
#   flux-pro-1.1 — фотогенично-иллюстративный, ~3.6 ₽
#   flux-dev     — заметно лучше Schnell, ~2.3 ₽
#   flux-schnell — дёшево и сердито, 0.3 ₽
# Платится через FAL.AI — один ключ FAL_KEY для всех моделей.
# FusionBrain (Kandinsky) — legacy fallback, если задан — используется когда FAL недоступен.
# ============================
IMAGE_MODEL=recraft-v3
FAL_KEY=

# FusionBrain (legacy fallback). Если хочешь полностью отключить — оставь пустыми.
FUSIONBRAIN_API_KEY=
FUSIONBRAIN_SECRET_KEY=

# ============================
# БД
# ============================
DB_URL=postgresql+asyncpg://skazka:skazka@db:5432/skazka

# ============================
# Лимиты / тарифы (копейки)
# ============================
# Бесплатных сказок нет — с мая 2026 юзер видит витринный образец
# (готовая статическая сказка) и сразу платит за персональную.
# Поставь 1 если хочешь временно вернуть «первая бесплатно».
FREE_STORY_LIMIT=0
REFERRAL_BONUS=3

# Разово — одна сказка. После ребрендинга (май 2026) — 149₽ премиум.
PRICE_SINGLE_KOPECKS=14900

# Пакет 15 сказок — УБРАН ИЗ UI с мая 2026 (премиум-фокус на single+monthly).
# Переменные оставлены для backward-compat. UI кнопку показывать перестали,
# handler в billing.py живёт — легко вернуть если потребуется.
PRICE_PACK_KOPECKS=99900
PACK_STORIES_COUNT=15

# Подписка на календарный месяц (одна сказка в день, рекуррент) — 2990₽.
# При 30 сказках выходит ~99₽ за каждую + защита от «забыл купить».
PRICE_MONTHLY_KOPECKS=299000

# Подарочная сказка (если оставляешь функцию /gift) — отдельный товар
PRICE_GIFT_KOPECKS=19900

# ============================
# Канальная воронка (демонстрация продукта)
# ============================
# Каждый день в 18:00 МСК бот публикует одну сказку в канал — обложка +
# PDF + caption. Каждый 3-й пост содержит CTA-ссылку на сам бот.
# Бот должен быть админом канала с правом «отправлять сообщения».
CHANNEL_PUBLISH_ENABLED=false
# Формат: @username (публичный канал) или -1001234567890 (приватный)
CHANNEL_ID=
# Каждый N-й пост содержит CTA. Дефолт 3.
CHANNEL_CTA_EVERY_N=3
# Час публикации по МСК. Дефолт 18.
CHANNEL_PUBLISH_HOUR_MSK=18

# ============================
# Прочее
# ============================
ENV=production
LOG_LEVEL=INFO
SENTRY_DSN=
AUDIO_CACHE_DIR=./cache/audio
IMAGE_CACHE_DIR=./cache/images
